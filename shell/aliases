# dotfiles root
DOTFILES="${DOTFILES:-$HOME/dotfiles}"

# resource whichever shell (detects the running shell, not login shell)
function rsc {
    if [ -n "$ZSH_VERSION" ]; then
        source ~/.zshrc
    elif [ -n "$BASH_VERSION" ]; then
        source ~/.bashrc
    fi
    echo "reloaded"
}

