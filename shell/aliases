# https://askubuntu.com/a/22043
alias sudo='sudo '

# list space in a directory
alias sp='du -cksh ./* | sort -rh'
alias spd='du -cksh ./* .[^.]* | sort -rh'
alias susp='sudo sp'

# count number of files in a directory
alias count='ls -1 | wc -l'
alias countall='find . -type f | wc -l'

# kill all processes of current user (with confirmation)
function kys {
    echo "This will kill ALL your processes (including this shell)."
    printf "Are you sure? [y/N] "
    read -r confirm
    if [ "$confirm" = "y" ] || [ "$confirm" = "Y" ]; then
        pkill -u "$USER"
    fi
}


### MODERN CLI UPGRADES #################
# These only activate if the tool is installed.
# On Mac: `brew bundle` installs them.
# On clusters: they activate if available, otherwise silently skip.

# eza -> ls (colored, git-aware listings)
if command -v eza &>/dev/null; then
    alias ls="eza"
    alias ll="eza -la --git"
    alias lt="eza -laT --level=2"  # tree view
fi

# bat -> cat (syntax highlighting, line numbers)
if command -v bat &>/dev/null; then
    alias cat="bat --paging=never"
    alias catp="bat"               # bat with pager
fi

# fd (simpler find, respects .gitignore)
if command -v fd &>/dev/null; then
    alias ff="fd"
fi

# ripgrep (faster grep, .gitignore-aware — use `rg` directly, don't shadow grep)
if command -v rg &>/dev/null; then
    alias rgrep="rg"
fi


