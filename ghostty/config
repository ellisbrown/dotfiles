# aesthetics
background-opacity = 0.8
background-blur = 16
# background = #000000
# dim unfocused panes
unfocused-split-opacity = 0.7
unfocused-split-fill = #020202
split-divider-color = #808080


# theme
# theme = Argonaut
# theme = Firefly Traditional
# theme = Github Dark Default
# theme = Github Dark
# theme = Monokai Remastered
# theme = Synthwave

# auto-switches with system theme
# theme = dark:Catppuccin Frappe,light:Catppuccin Latte
# theme = dark:Github Dark Default,light:Github Light Default
# theme = dark:Github Dark Default,light:Primary
theme = dark:Firefly Traditional,light:Primary

# make Option key send Alt/Meta (needed for tmux Alt bindings)
macos-option-as-alt = true

# typography
font-size = 14
font-thicken = true
font-thicken-strength = 1
adjust-cell-height = 1